{$DOMAIN} {
  encode zstd gzip

  @api path /api/*
  reverse_proxy @api superfcai:3001

  # Serve the app
  reverse_proxy superfcai:3001

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
    
    # Ensure custom headers for SuperFCAI are explicitly handled if needed
    # Caddy preserves them by default, but this section is for security hardening
  }

  tls {$TLS_EMAIL}
}
