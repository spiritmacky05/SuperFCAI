# Gemini API Key (Required for AI features)
GEMINI_API_KEY=

# PayMongo Payment Gateway (Required for payments)
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
# Optional: comma-separated payment methods for checkout session
# Example: card,gcash,maya
PAYMONGO_PAYMENT_METHOD_TYPES=card,gcash

# Database file path (optional)
# For Docker compose this is set to /app/data/database.sqlite
DB_FILE=database.sqlite

# HTTPS / Reverse Proxy (Caddy)
# Use your real domain pointed to VPS public IP.
DOMAIN=example.com
TLS_EMAIL=admin@example.com

# Security Settings
# Comma-separated allowed origins for browser requests.
# Example: https://your-domain.com,https://admin.your-domain.com
CORS_ORIGINS=

# API rate limiting
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
