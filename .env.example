# SuperFCAI Environment Variables Template
# Copy this file to .env and fill in the values.
# DO NOT commit the .env file to version control.

# --- Backend Configuration ---
NODE_ENV=production
# PORT=3001
# DB_FILE=/app/data/database.sqlite

# --- AI Integration (Gemini) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Payment Integration (PayMongo) ---
PAYMONGO_SECRET_KEY=your_paymongo_secret_key_here
PAYMONGO_WEBHOOK_SECRET=your_webhook_secret_here
PAYMONGO_PAYMENT_METHOD_TYPES=card,paymaya,gcash

# --- Deployment / HTTPS (Caddy) ---
DOMAIN=yourdomain.com
TLS_EMAIL=admin@yourdomain.com

# --- Mail Server (Hostinger/SMTP) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=your-email@superfcai.tech
SMTP_PASS=your_email_password
FRONTEND_URL=https://superfcai.tech
