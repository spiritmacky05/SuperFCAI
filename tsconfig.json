{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "vite/client"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",

    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["src", "index.tsx", "App.tsx", "types.ts", "vite.config.ts", "components/**/*", "services/**/*"],
  "exclude": ["node_modules", "server.ts", "test_db.ts", "seed_db.ts", "dist"]
}